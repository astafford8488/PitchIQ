{
  "mailer_subjects_confirmation": "Confirm your PitchIQ account",
  "mailer_templates_confirmation_content": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Confirm your signup</title></head><body style=\"margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f5f5f5;color:#0c0c0c;padding:24px\"><div style=\"max-width:480px;margin:0 auto;background:#fff;border-radius:12px;padding:32px;box-shadow:0 2px 8px rgba(0,0,0,0.06)\"><h1 style=\"margin:0 0 8px;font-size:24px;color:#0c0c0c\">Confirm your email</h1><p style=\"margin:0 0 24px;color:#666;font-size:16px;line-height:1.5\">Thanks for signing up for PitchIQ — AI-powered podcast guest outreach. Click the button below to confirm your account.</p><p style=\"margin:0 0 24px\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;background:#e8b86d;color:#0c0c0c;text-decoration:none;font-weight:600;padding:14px 24px;border-radius:8px;font-size:16px\">Confirm email</a></p><p style=\"margin:0;color:#999;font-size:14px\">If you didn't create an account, you can ignore this email.</p><hr style=\"border:none;border-top:1px solid #eee;margin:24px 0\"><p style=\"margin:0;font-size:12px;color:#999\">PitchIQ · AI-powered podcast guest outreach</p></div></body></html>",
  "mailer_subjects_magic_link": "Your PitchIQ sign-in link",
  "mailer_templates_magic_link_content": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Sign in to PitchIQ</title></head><body style=\"margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f5f5f5;color:#0c0c0c;padding:24px\"><div style=\"max-width:480px;margin:0 auto;background:#fff;border-radius:12px;padding:32px;box-shadow:0 2px 8px rgba(0,0,0,0.06)\"><h1 style=\"margin:0 0 8px;font-size:24px;color:#0c0c0c\">Sign in to PitchIQ</h1><p style=\"margin:0 0 24px;color:#666;font-size:16px;line-height:1.5\">Use the button below to sign in. This link is valid for a short time.</p><p style=\"margin:0 0 24px\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;background:#e8b86d;color:#0c0c0c;text-decoration:none;font-weight:600;padding:14px 24px;border-radius:8px;font-size:16px\">Sign in</a></p><p style=\"margin:0;color:#999;font-size:14px\">If you didn't request this, you can ignore this email.</p><hr style=\"border:none;border-top:1px solid #eee;margin:24px 0\"><p style=\"margin:0;font-size:12px;color:#999\">PitchIQ · AI-powered podcast guest outreach</p></div></body></html>",
  "mailer_subjects_recovery": "Reset your PitchIQ password",
  "mailer_templates_recovery_content": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Reset password</title></head><body style=\"margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f5f5f5;color:#0c0c0c;padding:24px\"><div style=\"max-width:480px;margin:0 auto;background:#fff;border-radius:12px;padding:32px;box-shadow:0 2px 8px rgba(0,0,0,0.06)\"><h1 style=\"margin:0 0 8px;font-size:24px;color:#0c0c0c\">Reset your password</h1><p style=\"margin:0 0 24px;color:#666;font-size:16px;line-height:1.5\">We received a request to reset the password for your PitchIQ account. Click below to set a new password.</p><p style=\"margin:0 0 24px\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;background:#e8b86d;color:#0c0c0c;text-decoration:none;font-weight:600;padding:14px 24px;border-radius:8px;font-size:16px\">Reset password</a></p><p style=\"margin:0;color:#999;font-size:14px\">If you didn't request this, you can ignore this email. Your password will stay the same.</p><hr style=\"border:none;border-top:1px solid #eee;margin:24px 0\"><p style=\"margin:0;font-size:12px;color:#999\">PitchIQ · AI-powered podcast guest outreach</p></div></body></html>",
  "mailer_subjects_invite": "You're invited to PitchIQ",
  "mailer_templates_invite_content": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>You're invited to PitchIQ</title></head><body style=\"margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f5f5f5;color:#0c0c0c;padding:24px\"><div style=\"max-width:480px;margin:0 auto;background:#fff;border-radius:12px;padding:32px;box-shadow:0 2px 8px rgba(0,0,0,0.06)\"><h1 style=\"margin:0 0 8px;font-size:24px;color:#0c0c0c\">You're invited to PitchIQ</h1><p style=\"margin:0 0 24px;color:#666;font-size:16px;line-height:1.5\">You've been invited to create an account on PitchIQ — AI-powered podcast guest outreach. Click below to accept the invite and get started.</p><p style=\"margin:0 0 24px\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;background:#e8b86d;color:#0c0c0c;text-decoration:none;font-weight:600;padding:14px 24px;border-radius:8px;font-size:16px\">Accept invite</a></p><p style=\"margin:0;color:#999;font-size:14px\">This invite was sent to you for {{ .SiteURL }}.</p><hr style=\"border:none;border-top:1px solid #eee;margin:24px 0\"><p style=\"margin:0;font-size:12px;color:#999\">PitchIQ · AI-powered podcast guest outreach</p></div></body></html>",
  "mailer_subjects_reauthentication": "Confirm it's you — PitchIQ",
  "mailer_templates_reauthentication_content": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Confirm reauthentication</title></head><body style=\"margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f5f5f5;color:#0c0c0c;padding:24px\"><div style=\"max-width:480px;margin:0 auto;background:#fff;border-radius:12px;padding:32px;box-shadow:0 2px 8px rgba(0,0,0,0.06)\"><h1 style=\"margin:0 0 8px;font-size:24px;color:#0c0c0c\">Confirm it's you</h1><p style=\"margin:0 0 24px;color:#666;font-size:16px;line-height:1.5\">Enter this code in PitchIQ to continue:</p><p style=\"margin:0 0 24px;font-size:28px;font-weight:700;letter-spacing:4px;color:#e8b86d\">{{ .Token }}</p><p style=\"margin:0;color:#999;font-size:14px\">This code expires soon. If you didn't request it, you can ignore this email.</p><hr style=\"border:none;border-top:1px solid #eee;margin:24px 0\"><p style=\"margin:0;font-size:12px;color:#999\">PitchIQ · AI-powered podcast guest outreach</p></div></body></html>",
  "mailer_subjects_email_change": "Confirm your new email — PitchIQ",
  "mailer_templates_email_change_content": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Confirm email change</title></head><body style=\"margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f5f5f5;color:#0c0c0c;padding:24px\"><div style=\"max-width:480px;margin:0 auto;background:#fff;border-radius:12px;padding:32px;box-shadow:0 2px 8px rgba(0,0,0,0.06)\"><h1 style=\"margin:0 0 8px;font-size:24px;color:#0c0c0c\">Confirm your new email</h1><p style=\"margin:0 0 24px;color:#666;font-size:16px;line-height:1.5\">You requested to change the email for your PitchIQ account to {{ .NewEmail }}. Click below to confirm.</p><p style=\"margin:0 0 24px\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;background:#e8b86d;color:#0c0c0c;text-decoration:none;font-weight:600;padding:14px 24px;border-radius:8px;font-size:16px\">Confirm new email</a></p><p style=\"margin:0;color:#999;font-size:14px\">If you didn't request this change, you can ignore this email.</p><hr style=\"border:none;border-top:1px solid #eee;margin:24px 0\"><p style=\"margin:0;font-size:12px;color:#999\">PitchIQ · AI-powered podcast guest outreach</p></div></body></html>",
  "mailer_notifications_password_changed_enabled": true,
  "mailer_subjects_password_changed_notification": "Your PitchIQ password was changed",
  "mailer_templates_password_changed_notification_content": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Password changed</title></head><body style=\"margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f5f5f5;color:#0c0c0c;padding:24px\"><div style=\"max-width:480px;margin:0 auto;background:#fff;border-radius:12px;padding:32px;box-shadow:0 2px 8px rgba(0,0,0,0.06)\"><h1 style=\"margin:0 0 8px;font-size:24px;color:#0c0c0c\">Password changed</h1><p style=\"margin:0 0 24px;color:#666;font-size:16px;line-height:1.5\">The password for your PitchIQ account ({{ .Email }}) was recently changed.</p><p style=\"margin:0;color:#999;font-size:14px\">If you didn't make this change, please contact support or secure your account.</p><hr style=\"border:none;border-top:1px solid #eee;margin:24px 0\"><p style=\"margin:0;font-size:12px;color:#999\">PitchIQ · AI-powered podcast guest outreach</p></div></body></html>",
  "mailer_notifications_email_changed_enabled": true,
  "mailer_subjects_email_changed_notification": "Your PitchIQ email address was changed",
  "mailer_templates_email_changed_notification_content": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Email changed</title></head><body style=\"margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f5f5f5;color:#0c0c0c;padding:24px\"><div style=\"max-width:480px;margin:0 auto;background:#fff;border-radius:12px;padding:32px;box-shadow:0 2px 8px rgba(0,0,0,0.06)\"><h1 style=\"margin:0 0 8px;font-size:24px;color:#0c0c0c\">Email address changed</h1><p style=\"margin:0 0 24px;color:#666;font-size:16px;line-height:1.5\">The email for your PitchIQ account was changed from {{ .OldEmail }} to {{ .Email }}.</p><p style=\"margin:0;color:#999;font-size:14px\">If you didn't make this change, please contact support immediately.</p><hr style=\"border:none;border-top:1px solid #eee;margin:24px 0\"><p style=\"margin:0;font-size:12px;color:#999\">PitchIQ · AI-powered podcast guest outreach</p></div></body></html>",
  "mailer_notifications_phone_changed_enabled": true,
  "mailer_subjects_phone_changed_notification": "Your PitchIQ phone number was changed",
  "mailer_templates_phone_changed_notification_content": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Phone changed</title></head><body style=\"margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f5f5f5;color:#0c0c0c;padding:24px\"><div style=\"max-width:480px;margin:0 auto;background:#fff;border-radius:12px;padding:32px;box-shadow:0 2px 8px rgba(0,0,0,0.06)\"><h1 style=\"margin:0 0 8px;font-size:24px;color:#0c0c0c\">Phone number changed</h1><p style=\"margin:0 0 24px;color:#666;font-size:16px;line-height:1.5\">The phone number for your PitchIQ account ({{ .Email }}) was changed from {{ .OldPhone }} to {{ .Phone }}.</p><p style=\"margin:0;color:#999;font-size:14px\">If you didn't make this change, please contact support immediately.</p><hr style=\"border:none;border-top:1px solid #eee;margin:24px 0\"><p style=\"margin:0;font-size:12px;color:#999\">PitchIQ · AI-powered podcast guest outreach</p></div></body></html>",
