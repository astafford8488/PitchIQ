# Supabase (required) — create project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: OpenAI for AI pitch generation (use free credits; cap usage in app)
OPENAI_API_KEY=

# Optional: Resend for sending pitches (free tier ~100/day). Leave empty to use "Copy to clipboard" only.
RESEND_API_KEY=

# Listen Notes API — for podcast discovery (get key at https://www.listennotes.com/api/)
LISTEN_NOTES_API_KEY=

# Stripe — subscription billing (Dashboard → Products → each price has a price_xxx ID)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=   # $20/mo
STRIPE_PRICE_ID_PLATINUM=  # $50/mo (Growth tier)
STRIPE_PRICE_ID_GROWTH=    # $100/mo (Platinum tier)

# Admin (comma-separated). Admins get /admin dashboard and Beta feature access.
ADMIN_EMAILS=thegatesoftroy@gmail.com, admin@youraigroup.com
ADMIN_USER_IDS=

# Optional: From address for affiliate approval emails (Resend). Requires RESEND_API_KEY.
RESEND_FROM_EMAIL=PitchIQ <admin@pitchiq.live>
